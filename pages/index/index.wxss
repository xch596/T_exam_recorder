/* pages/index/index.wxss */
page {
  background-color: #f5f6fa;
  height: 100%;
}

.container-home {
  height: 100%;
  display: flex;
  flex-direction: column;
}

/* 顶部筛选栏 */
.filter-bar {
  display: flex;
  background: #fff;
  padding: 20rpx 10rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.filter-item {
  flex: 1;
  text-align: center;
}

.picker-text {
  font-size: 28rpx;
  color: #666;
  background: #f0f2f5;
  padding: 10rpx 0;
  margin: 0 10rpx;
  border-radius: 8rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.picker-text.active {
  color: #1890ff;
  background: #e6f7ff;
  font-weight: bold;
}

.arrow {
  font-size: 20rpx;
  margin-left: 6rpx;
}

/* 滚动内容区 */
.content-scroll {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 分组卡片 */
.group-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}

.group-header {
  padding: 24rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-bottom: 1rpx solid #f5f5f5;
}

.group-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.paper-btn {
  padding: 0 18rpx !important;
  height: 54rpx;
  line-height: 54rpx;
  font-size: 24rpx;
  background: #f6ffed;
  color: #52c41a;
  border: 1rpx solid #52c41a;
}

.paper-btn[disabled] {
  background: #f5f5f5 !important;
  color: #bbb !important;
  border: 1rpx solid #ddd !important;
}

.paper-select-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 30rpx;
  background: #fffbe6;
  border-bottom: 1rpx solid #ffe58f;
}

.paper-select-text {
  font-size: 26rpx;
  color: #333;
}

.paper-cancel-btn {
  padding: 0 18rpx !important;
  height: 54rpx;
  line-height: 54rpx;
  font-size: 24rpx;
  background: #fff;
  color: #333;
  border: 1rpx solid #ddd;
}

.group-title-box {
  display: flex;
  align-items: center;
}

.folder-icon {
  margin-right: 16rpx;
  font-size: 36rpx;
}

.group-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 10rpx;
}

.group-count {
  font-size: 24rpx;
  color: #999;
}

.arrow-icon {
  font-size: 24rpx;
  color: #ccc;
  transition: transform 0.3s;
}

.arrow-icon.rotate {
  transform: rotate(90deg);
}

/* 题目列表项 */
.group-content {
  background: #fafafa;
}

.record-item {
  display: flex;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #eee;
  background: #fff;
}

.select-box {
  width: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.select-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  border: 2rpx solid #bbb;
  background: #fff;
  box-sizing: border-box;
}

.select-dot.checked {
  border-color: #07c160;
  background: #07c160;
}

.record-item:last-child {
  border-bottom: none;
}

.record-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  margin-right: 24rpx;
  background-color: #eee;
  flex-shrink: 0;
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.tags-row {
  display: flex;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: #e6f7ff;
  color: #1890ff;
  border-radius: 6rpx;
}

.record-note {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.record-date {
  font-size: 22rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
}

.empty-img {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.sub-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* FAB 按钮 */
.fab-btn {
  position: fixed;
  bottom: 60rpx;
  right: 40rpx;
  width: 110rpx;
  height: 110rpx;
  background: linear-gradient(135deg, #07c160, #38d684);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.4);
  z-index: 200;
}

.plus-icon {
  color: #fff;
  font-size: 60rpx;
  line-height: 1;
  margin-top: -8rpx;
}

.paper-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
}
