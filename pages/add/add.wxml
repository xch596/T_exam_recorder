<!--pages/add/add.wxml-->
<view class="container-add">
  <!-- 1. 图片处理区域 -->
  <view class="image-section">
    <image 
      class="preview-img" 
      src="{{processedImagePath || imagePath}}" 
      mode="aspectFit" 
      wx:if="{{imagePath}}"
      bindtap="chooseImage"
    ></image>
    <view class="placeholder" bindtap="chooseImage" wx:else>
      <text class="camera-icon">📷</text>
      <text>点击拍摄/选择试题</text>
    </view>
    
    <!-- 重新选择提示 -->
    <view class="re-choose-tip" wx:if="{{imagePath}}" bindtap="chooseImage">点击更换图片</view>
  </view>

  <!-- 工具栏：仅当有图片时显示 -->
  <view class="tool-bar" wx:if="{{imagePath}}">
    <button class="tool-btn ai-btn" bindtap="processImage" disabled="{{isProcessing}}">
      ✨ 智能去笔迹
    </button>
    <button class="tool-btn crop-btn" bindtap="openCrop" wx:if="{{processedImagePath}}" disabled="{{isProcessing}}">
      ⬛ 手动框题
    </button>
  </view>

  <!-- 2. 分类选择区域 -->
  <view class="form-section">
    <view class="form-item">
      <text class="label">科目</text>
      <picker bindchange="onSubjectChange" value="{{subjectIndex}}" range="{{subjects}}">
        <view class="picker-value">{{subjects[subjectIndex]}} ▼</view>
      </picker>
    </view>
    <view class="form-item">
      <text class="label">年级</text>
      <picker bindchange="onGradeChange" value="{{gradeIndex}}" range="{{grades}}">
        <view class="picker-value">{{grades[gradeIndex]}} ▼</view>
      </picker>
    </view>
    <view class="form-item">
      <text class="label">学期</text>
      <picker bindchange="onSemesterChange" value="{{semesterIndex}}" range="{{semesters}}">
        <view class="picker-value">{{semesters[semesterIndex]}} ▼</view>
      </picker>
    </view>
  </view>

  <!-- 3. 备注区域 -->
  <view class="form-section">
    <text class="label-block">备注/题目描述：</text>
    <textarea 
      class="note-input" 
      placeholder="请输入关于这道题的备注..." 
      bindinput="onInputNote"
      value="{{note}}"
    ></textarea>
  </view>

  <button class="save-btn" bindtap="saveRecord" disabled="{{!imagePath}}">保存至错题本</button>
</view>

<view class="crop-mask" wx:if="{{cropMode}}">
  <view class="crop-panel">
    <view class="crop-title">拖动选择要保存的区域</view>
    <view class="crop-image-wrap" id="cropWrap" bindtouchstart="onCropTouchStart" bindtouchmove="onCropTouchMove" bindtouchend="onCropTouchEnd">
      <image id="cropImage" class="crop-image" src="{{cropDisplaySrc}}" mode="widthFix" bindload="onCropImageLoad" binderror="onCropImageError"></image>
      <view class="crop-rect" wx:if="{{cropRectActive}}" style="left:{{cropRectLeft}}px;top:{{cropRectTop}}px;width:{{cropRectWidth}}px;height:{{cropRectHeight}}px;" catchtouchstart="onRectTouchStart" catchtouchmove="onRectTouchMove" catchtouchend="onRectTouchEnd">
        <view class="crop-handle tl" catchtouchstart="onHandleTouchStart" catchtouchmove="onHandleTouchMove" catchtouchend="onHandleTouchEnd" data-handle="tl"></view>
        <view class="crop-handle tr" catchtouchstart="onHandleTouchStart" catchtouchmove="onHandleTouchMove" catchtouchend="onHandleTouchEnd" data-handle="tr"></view>
        <view class="crop-handle bl" catchtouchstart="onHandleTouchStart" catchtouchmove="onHandleTouchMove" catchtouchend="onHandleTouchEnd" data-handle="bl"></view>
        <view class="crop-handle br" catchtouchstart="onHandleTouchStart" catchtouchmove="onHandleTouchMove" catchtouchend="onHandleTouchEnd" data-handle="br"></view>
      </view>
    </view>
    <view class="crop-actions">
      <button class="crop-action-btn cancel" bindtap="closeCrop">取消</button>
      <button class="crop-action-btn ok" bindtap="confirmCropAndSave" disabled="{{!cropRectActive}}">保存</button>
    </view>
  </view>
</view>

<canvas canvas-id="cropCanvas" class="crop-canvas" style="width:{{canvasW}}px;height:{{canvasH}}px;" width="{{canvasW}}" height="{{canvasH}}"></canvas>
