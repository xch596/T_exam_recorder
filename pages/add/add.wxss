/* pages/add/add.wxss */
.container-add {
  padding: 30rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.image-section {
  width: 100%;
  height: 400rpx;
  background-color: #fff;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  margin-bottom: 20rpx;
  border: 2rpx dashed #ddd;
  position: relative;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.re-choose-tip {
  position: absolute;
  bottom: 0;
  width: 100%;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 24rpx;
  text-align: center;
  padding: 10rpx 0;
}

.placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #999;
}

.camera-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.tool-bar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 30rpx;
  gap: 20rpx;
}

.tool-btn {
  font-size: 26rpx;
  padding: 10rpx 30rpx;
  margin: 0;
  border-radius: 30rpx;
}

.ai-btn {
  background: #e6f7ff;
  color: #1890ff;
  border: 1rpx solid #1890ff;
}

.crop-btn {
  background: #f6ffed;
  color: #52c41a;
  border: 1rpx solid #52c41a;
}

.form-section {
  background: #fff;
  padding: 0 30rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.form-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 100rpx;
  border-bottom: 1rpx solid #eee;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
}

.label-block {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  padding-top: 30rpx;
  display: block;
  margin-bottom: 20rpx;
}

.picker-value {
  font-size: 30rpx;
  color: #666;
}

.note-input {
  width: 100%;
  height: 150rpx;
  font-size: 28rpx;
  line-height: 1.5;
  margin-bottom: 30rpx;
}

.save-btn {
  background-color: #07c160;
  color: #fff;
  font-weight: bold;
  margin-top: 50rpx;
}

.save-btn[disabled] {
  background-color: #a0eac5 !important;
  color: #fff !important;
}

.crop-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.crop-panel {
  width: 92%;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
}

.crop-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.crop-image-wrap {
  position: relative;
  width: 100%;
  background: #000;
}

.crop-image {
  width: 100%;
  display: block;
}

.crop-rect {
  position: absolute;
  border: 3rpx solid #07c160;
  background: rgba(7, 193, 96, 0.12);
  box-sizing: border-box;
}

.crop-handle {
  position: absolute;
  width: 36rpx;
  height: 36rpx;
  background: #07c160;
  border: 4rpx solid #fff;
  border-radius: 50%;
  box-sizing: border-box;
}

.crop-handle.tl {
  left: -18rpx;
  top: -18rpx;
}

.crop-handle.tr {
  right: -18rpx;
  top: -18rpx;
}

.crop-handle.bl {
  left: -18rpx;
  bottom: -18rpx;
}

.crop-handle.br {
  right: -18rpx;
  bottom: -18rpx;
}

.crop-actions {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  gap: 20rpx;
}

.crop-action-btn {
  flex: 1;
}

.crop-action-btn.cancel {
  background: #f5f5f5;
  color: #333;
}

.crop-action-btn.ok {
  background: #07c160;
  color: #fff;
}

.crop-action-btn[disabled] {
  background: #a0eac5 !important;
  color: #fff !important;
}

.crop-canvas {
  position: fixed;
  left: 0;
  top: 0;
  opacity: 0;
  pointer-events: none;
}
